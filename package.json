{
  "name": "simple-pos",
  "version": "1.0.1",
  "description": "Simple POS and Inventory App for Car Repair Shop",
  "author": "krisnaw",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_DEV=true electron .\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/vite/bin/vite.js build",
    "build:electron": "ELECTRON_RUN_AS_NODE=1 electron ./node_modules/typescript/bin/tsc -p tsconfig.electron.json",
    "test": "vitest run --config vitest.config.mts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npm run build:electron && ELECTRON_RUN_AS_NODE=1 electron ./dist-electron/db/migrate.js .",
    "db:seed": "npm run build:electron && ELECTRON_RUN_AS_NODE=1 electron ./dist-electron/db/seeder/seed-products.js",
    "start": "npm run build && electron .",
    "dist:mac": "npm run dist:mac:silicon",
    "dist:mac:silicon": "npm run build && electron-builder --mac --arm64 --config.artifactName='${productName}-${version}-mac-Apple-Silicon.${ext}'",
    "dist:mac:intel": "npm run build && electron-builder --mac --x64 --config.artifactName='${productName}-${version}-mac-Intel.${ext}'",
    "dist:win": "npm run build && electron-builder --win --x64",
    "publish:mac": "npm run build && electron-builder --mac --arm64 --publish always",
    "publish:win": "npm run build && electron-builder --win --x64 --publish always"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.4",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.0.0",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.4.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0"
  },
  "build": {
    "appId": "com.simplepos.app",
    "productName": "SimplePOS",
    "electronUpdaterCompatibility": ">= 2.16",
    "directories": {
      "output": "release/builder"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "krisnaw",
        "repo": "SimplePOS"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
  }
}
