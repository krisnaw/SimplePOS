{
  "name": "simple-pos",
  "version": "1.0.0",
  "description": "Simple POS and Inventory App for Car Repair Shop",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && concurrently \"vite\" \"wait-on http://localhost:5173 && ELECTRON_DEV=true electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "start": "vite build && tsc -p tsconfig.electron.json && electron ."
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.0.0",
    "electron": "^42.3.0",
    "typescript": "^5.4.3",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "reflect-metadata": "^0.2.2",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "typeorm": "^0.3.30"
  }
}
